{
  "name": "saudi-realestate",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "turbo dev --filter=@saudi-re/web",
    "dev:api": "turbo dev --filter=@saudi-re/api",
    "build:web": "turbo build --filter=@saudi-re/web",
    "build:api": "turbo build --filter=@saudi-re/api",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.4.0"
  }
}
