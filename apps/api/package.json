{
  "name": "@saudi-re/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && ncc build src/index.ts -o dist --minify --no-cache",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "seed": "tsx src/scripts/prepare-testing.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/oauth2": "^8.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@google/generative-ai": "^0.24.1",
    "@neondatabase/serverless": "^0.9.0",
    "@saudi-re/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.34.0",
    "fastify": "^5.0.0",
    "fastify-type-provider-zod": "^6.1.0",
    "jsonwebtoken": "^9.0.0",
    "pino-pretty": "^13.1.3",
    "resend": "^6.10.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.12.7",
    "drizzle-kit": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "@vercel/ncc": "^0.38.1"
  }
}
